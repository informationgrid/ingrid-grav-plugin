{
  "name": "khanh-toan-tran/ingrid-grav",
  "type": "grav-plugin",
  "description": "InGrid functions for GravCMS",
  "keywords": ["plugin"],
  "homepage": "https://github.com/informationgrid/ingrid-grav-plugin",
  "license": "MIT",
  "authors": [
    {
      "name": "Khanh Toan Tran",
      "email": "khanh.toan.tran@wemove.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": ">=8.3",
    "guzzlehttp/guzzle": "^7.0",
    "guzzlehttp/psr7": "^1.7"
  },
  "require-dev": {
    "phpunit/phpunit": "^11"
  },
  "autoload": {
    "psr-4": {
      "Grav\\Plugin\\InGridGrav\\": "classes/"
    },
    "classmap":  ["ingrid-grav.php"],
    "files": [
      "classes/Catalog.php",
      "classes/CategoryFacet.php",
      "classes/Datasource.php",
      "classes/Detail.php",
      "classes/Help.php",
      "classes/HitOverview.php",
      "classes/Search.php",
      "classes/Provider.php",
      "classes/SimilarTerms.php",
      "classes/LayoutZDM.php",
      "classes/detail/DetailAddress.php",
      "classes/detail/DetailMetadata.php",
      "classes/detail/zip/DetailCreateZipService.php",
      "classes/detail/zip/DetailCreateZipUVPServiceImpl.php",
      "classes/search/model/SearchResult.php",
      "classes/search/model/SearchResultHit.php",
      "classes/search/model/FacetResult.php",
      "classes/search/model/FacetItem.php",
      "classes/search/model/FacetItemMulti.php",
      "classes/search/services/SearchService.php",
      "classes/search/services/SearchServiceImpl.php",
      "classes/search/services/transformer/SearchResponseTransformerClassic.php",
      "classes/search/services/parser/SearchResultParserClassicISO.php",
      "classes/search/services/parser/SearchResultParserClassicUVP.php"
    ]

  }
}
